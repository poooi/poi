{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "jsx": "react",
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "views/*": [
        "./views/*"
      ]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./shims/vendor"
    ],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "importHelpers": true,
    "moduleResolution": "nodenext",
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["eslint.config.mts"]
}
