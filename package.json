{
  "name": "poi",
  "version": "11.1.0",
  "description": "poi the KanColle Browser Tool",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "deploy:nightlies": "gulp deploy_nightlies",
    "build": "gulp build && electron-builder -p never --config electron-builder.config.js",
    "build:x64": "gulp build && cross-env ARCH=x64 electron-builder -p never --config electron-builder.config.js",
    "build:arm64": "gulp build && cross-env ARCH=arm64 electron-builder -p never --config electron-builder.config.js",
    "build:all": "gulp build && cross-env ARCH=all electron-builder -p never --config electron-builder.config.js",
    "build:full": "gulp build && cross-env FULL_TARGET=true ARCH=all electron-builder -p never --config electron-builder.config.js",
    "start": "electron .",
    "start_debug": "electron . --dev --inspect",
    "dev": "electron . --dev --inspect",
    "clean": "gulp clean",
    "lint:js": "eslint . --ext .es --ext .js --ext .ts --ext .tsx",
    "lint:js:fix": "eslint . --ext .es --ext .js --ext .ts --ext .tsx --fix",
    "lint:style": "stylelint '**/*.es' '**/*.css' '**/*.tsx'",
    "lint:style:fix": "stylelint '**/*.es' '**/*.css' '**/*.tsx' --fix",
    "lint": "npm run lint:js && npm run lint:style",
    "lint:fix": "npm run lint:js:fix && npm run lint:style:fix",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/poooi/poi.git"
  },
